<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - JourneyGenie</title>
    <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="content">
        <div class="leftSection">
            <div class="homeQuote">
                "Have questions? We're here to help!" 
            </div>
        </div>

        <div class="contactForm">
            <form>
                <ul>
                    <li><div>Contact Us</div></li>
                    <li><input type="text" placeholder="Full Name" required></li>
                    <li><input type="email" placeholder="Email" required></li>
                    <li><textarea placeholder="Your Message" rows="4" required></textarea></li>
                    <li><input type="submit" value="Send Message"></li>
                </ul>
            </form>
        </div>
    </div>
</body>
</html>